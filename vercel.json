{
  "version": 2,
  "functions": {
    "app/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/cron/scrape-jobs/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/scrape-linkedin-jobs/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/scrape-jobs",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/scrape-linkedin-jobs",
      "schedule": "0 9 * * *"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
